@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="text-primary border-bottom pb-3 mb-4">🛡️ @ViewData["Title"]</h1>

            <div class="card shadow-sm border-0 bg-light rounded-4">
                <div class="card-body p-5">
                    <h4 class="fw-bold mb-3">Data Storage & Collection</h4>
                    <p class="fs-5 text-secondary">
                        This is a demonstration and practice application. <strong>We do not collect, track, share, or sell any personal data.</strong>
                    </p>
                    
                    <div class="alert alert-info mt-4 border-info">
                        <h5 class="alert-heading fw-bold">ℹ️ In-Memory Database Notice</h5>
                        <p class="mb-0">
                            All product data entered into this system is stored in the server's temporary memory (RAM) using a static list. This means that once the application is restarted or the server stops, <strong>all data will be permanently erased</strong>.
                        </p>
                    </div>

                    <p class="text-muted mt-5 mb-0">
                        <small>Last updated: Today</small>
                    </p>
                </div>
            </div>
            
            <div class="mt-4 text-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4">
                    ⬅️ Back to Home
                </a>
            </div>
        </div>
    </div>
</div>