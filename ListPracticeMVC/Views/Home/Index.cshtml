@{
    ViewData["Title"] = "Home Page";
}

<div class="container text-center mt-5">
    <div class="bg-light p-5 rounded-4 shadow-sm border">
        <h1 class="display-4 fw-bold text-primary mb-3">📦 Welcome to Product Manager</h1>
        <p class="lead text-secondary fs-4">A fast, simple, and intuitive system to manage your inventory.</p>
        
        <hr class="my-4 border-secondary opacity-25">
        
        <p class="mb-4 text-muted">
            This application demonstrates full <strong>CRUD operations</strong> (Create, Read, Update, Delete) 
            built with ASP.NET Core MVC using an efficient in-memory data structure.
        </p>
        
        <div class="mt-4">
            <a asp-controller="Product" asp-action="ProductsList" class="btn btn-primary btn-lg px-5 py-3 shadow fw-bold rounded-pill">
                🚀 Go to Products Dashboard
            </a>
        </div>
    </div>

    <div class="row mt-5 text-start g-4">
        <div class="col-md-4">
            <div class="p-4 border rounded-3 shadow-sm h-100">
                <h4 class="text-success">➕ Easy to Add</h4>
                <p class="text-muted">Quickly add new products to your inventory with images, prices, and detailed descriptions.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 border rounded-3 shadow-sm h-100">
                <h4 class="text-warning">✏️ Quick Updates</h4>
                <p class="text-muted">Modify product details on the fly. Keep your pricing and information up to date effortlessly.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 border rounded-3 shadow-sm h-100">
                <h4 class="text-danger">🗑️ Safe Deletion</h4>
                <p class="text-muted">Remove discontinued items from your list safely with built-in confirmation steps.</p>
            </div>
        </div>
    </div>
</div>