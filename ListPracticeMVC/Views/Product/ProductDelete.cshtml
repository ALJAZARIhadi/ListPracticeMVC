@model ListPracticeMVC.Models.Product

@{
    ViewData["Title"] = "Product Details & Delete";
}

<div class="container mt-4">
    <h2>ℹ️ Product Details</h2>
    <hr />

    <div class="row">
        <div class="col-md-8 offset-md-2">
            
            <div class="card shadow border-danger mb-4">
                <div class="row g-0">
                    <div class="col-md-4 d-flex align-items-center bg-light p-2">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.Name">
                        }
                        else
                        {
                            <div class="w-100 text-center text-muted p-5">📷 No Image Available</div>
                        }
                    </div>
                    
                    <div class="col-md-8">
                        <div class="card-body">
                            <h3 class="card-title text-primary fw-bold">@Model.Name</h3>
                            <h4 class="text-success mb-3">@Model.Price $</h4>
                            <p class="card-text">
                                <strong>Description:</strong> 
                                @(string.IsNullOrEmpty(Model.Description) ? "No description available." : Model.Description)
                            </p>
                            <p class="card-text"><small class="text-muted">Product ID: @Model.Id</small></p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-danger text-center shadow-sm">
                <h5 class="fw-bold">⚠️ Are you sure you want to delete this product permanently?</h5>
                <p>This action cannot be undone.</p>
                
                <form asp-controller="Product" asp-action="ProductDelete" method="post" class="mt-3">
                    <input type="hidden" asp-for="Id" />
                    
                    <button type="submit" class="btn btn-danger fw-bold px-4 py-2">
                        🗑️ Yes, Delete Product
                    </button>
                    <a asp-controller="Product" asp-action="ProductsList" class="btn btn-secondary px-4 py-2">
                        ❌ Cancel & Go Back
                    </a>
                </form>
            </div>

        </div>
    </div>
</div>