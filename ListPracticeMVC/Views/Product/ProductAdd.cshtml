@model ListPracticeMVC.Models.Product

@{
    ViewData["Title"] = "Add New Product";
}

<div class="container mt-4">
    <h2 class="text-primary">➕ Add New Product</h2>
    <hr />

    <div class="row">
        <div class="col-md-8 shadow-sm p-4 bg-light rounded border">
            <form asp-controller="Product" asp-action="ProductAdd" method="post">
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Product Name</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Gaming Laptop 1TB SSD..." required />
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label fw-bold">Price ($)</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter product specifications and details here..."></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="ImageUrl" class="form-label fw-bold">Image URL</label>
                    <input asp-for="ImageUrl" type="url" class="form-control" placeholder="https://example.com/image.jpg" />
                    <small class="text-muted">Copy an image link from the web and paste it here.</small>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success px-4 fw-bold">💾 Save Product</button>
                    <a asp-controller="Product" asp-action="ProductsList" class="btn btn-secondary px-4">❌ Cancel & Back</a>
                </div>

            </form>
        </div>
    </div>
</div>